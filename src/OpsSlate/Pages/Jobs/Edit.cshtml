@page "{id}"
@model OpsSlate.Pages.Jobs.EditModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit @Model.Input.JobId - OpsSlate</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<main class="container detail-container">
    <a class="back-link" asp-page="/Jobs/Details" asp-route-id="@Model.Input.JobId">← Back to job details</a>
    <h1>Edit Job</h1>
    <p>Update the selected job in <code>@Model.ConfigPath</code>. Job IDs are read-only in v1.</p>

    <section class="form-card" aria-labelledby="edit-job-heading">
        <div class="detail-header">
            <div>
                <span class="detail-label">Edit Job Workflow v1</span>
                <h2 id="edit-job-heading">@Model.Input.JobId</h2>
                <p>The jobs file is backed up, job order is preserved, and only the selected job is changed.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.StatusWarning))
        {
            <div class="edit-warning">@Model.StatusWarning</div>
        }

        <form method="post" class="job-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-grid">
                <div class="form-field">
                    <label asp-for="Input.JobId"></label>
                    <input asp-for="Input.JobId" readonly />
                    <span asp-validation-for="Input.JobId" class="field-validation"></span>
                    <small>Job ID editing is intentionally disabled in v1.</small>
                </div>

                <div class="form-field">
                    <label asp-for="Input.JobName"></label>
                    <input asp-for="Input.JobName" autocomplete="off" />
                    <span asp-validation-for="Input.JobName" class="field-validation"></span>
                </div>

                <div class="form-field form-field-wide">
                    <label asp-for="Input.StatusPath"></label>
                    <input asp-for="Input.StatusPath" autocomplete="off" />
                    <span asp-validation-for="Input.StatusPath" class="field-validation"></span>
                    <small>Absolute paths are used as-is. Relative paths resolve under <code>@Model.StatusRoot</code>.</small>
                </div>

                <div class="form-field">
                    <label asp-for="Input.StaleAfterMinutes"></label>
                    <input asp-for="Input.StaleAfterMinutes" min="1" type="number" />
                    <span asp-validation-for="Input.StaleAfterMinutes" class="field-validation"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.DependsOn"></label>
                    <input asp-for="Input.DependsOn" autocomplete="off" placeholder="health_check, backup_nas" />
                    <span asp-validation-for="Input.DependsOn" class="field-validation"></span>
                    <small>Optional comma-separated existing job IDs. A job cannot depend on itself.</small>
                </div>
            </div>

            @if (Model.ExistingJobs.Count > 0)
            {
                <div class="existing-jobs-note">
                    <span class="detail-label">Existing job IDs</span>
                    <ul class="inline-list">
                        @foreach (var job in Model.ExistingJobs)
                        {
                            <li>@job.Id</li>
                        }
                    </ul>
                </div>
            }

            <div class="form-actions">
                <button type="submit" class="primary-button">Save Changes</button>
                <a class="dashboard-link" asp-page="/Jobs/Details" asp-route-id="@Model.Input.JobId">Cancel</a>
            </div>
        </form>
    </section>
</main>
</body>
</html>
