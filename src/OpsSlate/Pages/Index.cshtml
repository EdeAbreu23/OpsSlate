@page
@model OpsSlate.Pages.IndexModel
@{
    var totalJobs = Model.Jobs.Count;
    var errorJobs = Model.Jobs.Count(job => job.FinalStatus == JobFinalStatus.Error);
    var blockedJobs = Model.Jobs.Count(job => job.FinalStatus == JobFinalStatus.Blocked);
    var staleJobs = Model.Jobs.Count(job => job.FinalStatus == JobFinalStatus.Stale);
    var warningJobs = Model.Jobs.Count(job => job.FinalStatus == JobFinalStatus.Warning);
    var successJobs = Model.Jobs.Count(job => job.FinalStatus == JobFinalStatus.Success);
    var unknownJobs = Model.Jobs.Count(job => job.FinalStatus == JobFinalStatus.Unknown);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="refresh" content="@Model.AutoRefreshSeconds" />
    <title>OpsSlate</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<main class="container dashboard-container">
    <header class="brand-header page-hero">
        <span class="brand-kicker">Job Health Dashboard</span>
        <h1>OpsSlate</h1>
        <p>Dashboard overview of configured job health.</p>
    </header>
    <div class="refresh-actions">
        <p class="refresh-note">Auto-refreshes every @Model.AutoRefreshSeconds seconds.</p>
        <a class="refresh-now" href="@(Request.Path.ToString() + Request.QueryString.ToString())">Refresh Now</a>
        <a class="dashboard-link add-job-link" asp-page="/Jobs/New">Add Job</a>
        <a class="dashboard-link" asp-page="/System/Validation">System Validation</a>
        <a class="dashboard-link" asp-page="/System/Info">System Info</a>
    </div>

    <section class="summary-grid" aria-label="Job status summary">
        <article class="summary-card summary-total">
            <span class="summary-label">Total Jobs</span>
            <strong class="summary-value">@totalJobs</strong>
        </article>
        <article class="summary-card summary-error">
            <span class="summary-label">Errors</span>
            <strong class="summary-value">@errorJobs</strong>
        </article>
        <article class="summary-card summary-blocked">
            <span class="summary-label">Blocked</span>
            <strong class="summary-value">@blockedJobs</strong>
        </article>
        <article class="summary-card summary-stale">
            <span class="summary-label">Stale</span>
            <strong class="summary-value">@staleJobs</strong>
        </article>
        <article class="summary-card summary-warning">
            <span class="summary-label">Warnings</span>
            <strong class="summary-value">@warningJobs</strong>
        </article>
        <article class="summary-card summary-success">
            <span class="summary-label">Success</span>
            <strong class="summary-value">@successJobs</strong>
        </article>
        <article class="summary-card summary-unknown">
            <span class="summary-label">Unknown</span>
            <strong class="summary-value">@unknownJobs</strong>
        </article>
    </section>

    <section class="jobs-panel" aria-labelledby="jobs-table-heading">
        <div class="panel-header">
            <div>
                <span class="detail-label">Configured Jobs</span>
                <h2 id="jobs-table-heading">Current job status</h2>
            </div>
            <p>Sorted as configured. Scroll horizontally on small screens for all status fields.</p>
        </div>
        <div class="table-wrap">
    <table class="jobs-table">
        <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Details</th>
            <th>Edit</th>
            <th>Actions</th>
            <th>Final Status</th>
            <th>Reason</th>
            <th>Raw Status</th>
            <th>Last Run (UTC)</th>
            <th>Last Run Age</th>
            <th>Runtime</th>
            <th>Message</th>
            <th>Warnings</th>
            <th>Errors</th>
            <th>Stale</th>
            <th>File Found</th>
        </tr>
        </thead>
        <tbody>
        @if (!Model.Jobs.Any())
        {
            <tr>
                <td colspan="16" data-label="Jobs">No jobs found. Check the configured jobs file.</td>
            </tr>
        }
        else
        {
            foreach (var job in Model.Jobs)
            {
                <tr class="job-row status-@job.FinalStatus.ToLowerInvariant()">
                    <td data-label="ID" class="job-id">@job.Id</td>
                    <td data-label="Name" class="job-name">@job.Name</td>
                    <td data-label="Details"><a class="details-link" asp-page="/Jobs/Details" asp-route-id="@job.Id">View</a></td>
                    <td data-label="Edit"><a class="edit-link" asp-page="/Jobs/Edit" asp-route-id="@job.Id">Edit</a></td>
                    <td data-label="Actions"><a class="delete-link" asp-page="/Jobs/Delete" asp-route-id="@job.Id">Delete</a></td>
                    <td data-label="Final Status"><span class="badge @job.FinalStatus.ToLowerInvariant()">@job.FinalStatus</span></td>
                    <td data-label="Reason" class="reason-cell">@job.Reason</td>
                    <td data-label="Raw Status">@job.RawStatus</td>
                    <td data-label="Last Run (UTC)">@(job.LastRun?.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                    <td data-label="Last Run Age">@job.LastRunAge</td>
                    <td data-label="Runtime">@job.Runtime</td>
                    <td data-label="Message" class="message-cell">@job.Message</td>
                    <td data-label="Warnings">@job.Warnings</td>
                    <td data-label="Errors">@job.Errors</td>
                    <td data-label="Stale">@(job.IsStale ? "yes" : "no")</td>
                    <td data-label="File Found">@(job.FileFound ? "yes" : "no")</td>
                </tr>
            }
        }
        </tbody>
    </table>
        </div>
    </section>
</main>
</body>
</html>
