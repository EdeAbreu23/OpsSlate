@page
@model HomelabAutomationCenter.Pages.IndexModel
@{
    var totalJobs = Model.Jobs.Count;
    var errorJobs = Model.Jobs.Count(job => job.FinalStatus == "ERROR");
    var blockedJobs = Model.Jobs.Count(job => job.FinalStatus == "BLOCKED");
    var staleJobs = Model.Jobs.Count(job => job.FinalStatus == "STALE");
    var warningJobs = Model.Jobs.Count(job => job.FinalStatus == "WARNING");
    var successJobs = Model.Jobs.Count(job => job.FinalStatus == "SUCCESS");
    var unknownJobs = Model.Jobs.Count(job => job.FinalStatus == "UNKNOWN");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="refresh" content="@Model.AutoRefreshSeconds" />
    <title>Homelab Automation Center</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<main class="container">
    <h1>Homelab Automation Center</h1>
    <p>Dashboard overview of configured job health.</p>
    <p class="refresh-note">Auto-refreshes every @Model.AutoRefreshSeconds seconds.</p>

    <section class="summary-grid" aria-label="Job status summary">
        <article class="summary-card summary-total">
            <span class="summary-label">Total Jobs</span>
            <strong class="summary-value">@totalJobs</strong>
        </article>
        <article class="summary-card summary-error">
            <span class="summary-label">Errors</span>
            <strong class="summary-value">@errorJobs</strong>
        </article>
        <article class="summary-card summary-blocked">
            <span class="summary-label">Blocked</span>
            <strong class="summary-value">@blockedJobs</strong>
        </article>
        <article class="summary-card summary-stale">
            <span class="summary-label">Stale</span>
            <strong class="summary-value">@staleJobs</strong>
        </article>
        <article class="summary-card summary-warning">
            <span class="summary-label">Warnings</span>
            <strong class="summary-value">@warningJobs</strong>
        </article>
        <article class="summary-card summary-success">
            <span class="summary-label">Success</span>
            <strong class="summary-value">@successJobs</strong>
        </article>
        <article class="summary-card summary-unknown">
            <span class="summary-label">Unknown</span>
            <strong class="summary-value">@unknownJobs</strong>
        </article>
    </section>

    <div class="table-wrap">
    <table>
        <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Details</th>
            <th>Final Status</th>
            <th>Reason</th>
            <th>Raw Status</th>
            <th>Last Run (UTC)</th>
            <th>Runtime</th>
            <th>Message</th>
            <th>Warnings</th>
            <th>Errors</th>
            <th>Stale</th>
            <th>File Found</th>
        </tr>
        </thead>
        <tbody>
        @if (!Model.Jobs.Any())
        {
            <tr>
                <td colspan="13">No jobs found. Check /config/jobs.yml.</td>
            </tr>
        }
        else
        {
            foreach (var job in Model.Jobs)
            {
                <tr class="status-@job.FinalStatus.ToLowerInvariant()">
                    <td>@job.Id</td>
                    <td>@job.Name</td>
                    <td><a class="details-link" asp-page="/Jobs/Details" asp-route-id="@job.Id">View</a></td>
                    <td><span class="badge @job.FinalStatus.ToLowerInvariant()">@job.FinalStatus</span></td>
                    <td>@job.Reason</td>
                    <td>@job.RawStatus</td>
                    <td>@(job.LastRun?.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                    <td>@job.Runtime</td>
                    <td>@job.Message</td>
                    <td>@job.Warnings</td>
                    <td>@job.Errors</td>
                    <td>@(job.IsStale ? "yes" : "no")</td>
                    <td>@(job.FileFound ? "yes" : "no")</td>
                </tr>
            }
        }
        </tbody>
    </table>
    </div>
</main>
</body>
</html>
